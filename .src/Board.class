'---------------------------------------------------------
' map menu selections to arrays and character elimination
'---------------------------------------------------------
Public Sub MenuClicks2(i As Byte, j As Byte, k As Byte)
    op = i
    guess()

    Inc score[Data.player()]
    Label3.Text = "Score: " & (score[Data.player()] * 10)

    Data.printRemaining() ' console

    If chosen[Data.player(), j, k] Or Data.alive[Data.player()] = 0 Then
        If chosen[Data.player(), j, k] Then
            Message.Info("This trait was already selected. Please try again.", "Ok")
        Else
            Message.Info("All characters share this trait. Please try again.", "Ok")
            restoreBackup()
        Endif

        MenuButton1.Text = "Traits"
        MenuButton1.Menu = "Menu1"
        MenuButton1.Visible = True
        Button25.Enabled = True
        Button27.Visible = False
    Else
        MenuButton1.Visible = False
        MenuButton1.Text = "Traits"
        Button25.Enabled = False
        Button27.Visible = True
    Endif

    markEliminated()
    chosen[Data.player(), j, k] = True
End

