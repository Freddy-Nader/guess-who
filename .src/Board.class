' Gambas class file

score[2] As Byte

' guessing logic
trait As Byte
op As Byte
backup[24, 12] As String

' character elimination tracking
chosen[2, 10, 3] As Boolean

' object arrays
buttons[24] As Object
pb[7, 25] As Object             ' picture box
                                ' skin, outfit, eyes, freckles, features, hair, accessories (acc)
menus1[10, 4] As Object
menus2[10] As Object
menus3[10] As Object
bottomRow[24] As Object

Public Sub Form_Open()
    Dim i As Byte

    initArrays()
    setup()
    markEliminated()
End


'-------------------------------------------------------------------
' switch the "Traits" button to a button showing the selected trait
'-------------------------------------------------------------------
Public Sub MenuClicks1(i As Byte)
    trait = i
    MenuButton1.Text = Data.attr[i, 0]
    MenuButton1.Menu = Data.menu[i]

    Button25.Enabled = False
End

Public Sub trait00_Click()
    MenuClicks1(0)
End
