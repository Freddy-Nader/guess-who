'---------------------
' images and template
'---------------------
Public Sub setup()
    Dim i As Byte

    Button27.Visible = False
    Button25.Enabled = True

    Label4.Text = "Player " & (Data.player() + 1)
    Label3.Text = "Score: " & (score[Data.player()] * 10)

    For i = 0 To 23
        buttons[i].Text = Data.characters[i, 10]
        drawCharacter(i, i)
    Next

    ' hidden character
    i = Data.hidden[Data.player()]
    Label1.Text = Data.characters[i, 10]
    drawCharacter(i, 24)
End

Private Sub drawCharacter(src As Byte, dest As Byte)
    Dim k As Byte
    Dim m As Byte

    ' skin
    For k = 1 To 3
        If Data.characters[src, 1] = Data.attr[1, k] Then
            pb[0, dest].Picture = Picture["img/pb1" & k & ".png"]
            Break
        Endif
    Next

    ' outfit
    For k = 1 To 3
        If Data.characters[src, 2] = Data.attr[2, k] Then
            pb[1, dest].Picture = Picture["img/pb2" & k & ".png"]
            Break
        Endif
    Next

    ' eyes
    For k = 1 To 3
        For m = 1 To 3
            If Data.characters[src, 3] = Data.attr[3, k] And Data.characters[src, 4] = Data.attr[4, m] Then
                pb[2, dest].Picture = Picture["img/eyes" & k & m & ".png"]
                Break 2
            Endif
        Next
    Next

    ' freckles
    For k = 1 To 3
        If Data.characters[src, 5] = Data.attr[5, k] Then
            pb[3, dest].Picture = IIf(k = 3, Picture["img/empty.png"], Picture["img/pb5" & k & ".png"])
            Break
        Endif
    Next

    ' features
    For k = 1 To 3
        If Data.characters[src, 6] = Data.attr[6, k] Then
            pb[4, dest].Picture = IIf(k = 3, Picture["img/empty.png"], Picture["img/pb6" & k & ".png"])
            Break
        Endif
    Next

    ' hair
    If Data.characters[src, 7] = Data.attr[7, 3] Then
        pb[5, dest].Picture = Picture["img/empty.png"]
    Else
        For k = 1 To 2
            For m = 1 To 3
                If Data.characters[src, 7] = Data.attr[7, k] And Data.characters[src, 8] = Data.attr[8, m] Then
                    pb[5, dest].Picture = Picture["img/hair" & k & m & ".png"]
                    Break 2
                Endif
            Next
        Next
    Endif

    ' accessories
    For k = 1 To 3
        If Data.characters[src, 9] = Data.attr[9, k] Then
            pb[6, dest].Picture = IIf(k = 3, Picture["img/empty.png"], Picture["img/pb9" & k & ".png"])
            Break
        Endif
    Next
End
