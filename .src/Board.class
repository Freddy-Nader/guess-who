'----------------
' guessing logic
'----------------
Public Sub guess()
    Dim i As Byte
    Dim j As Byte
    Dim op1 As Byte
    Dim op2 As Byte

    ' save backup
    For i = 0 To 23
        For j = 0 To 10
            backup[i, j] = Data.characters[i, j]
        Next
        backup[i, j] = Data.mock[Data.player(), i]
    Next

    If Data.characters[Data.hidden[Data.opponentIndex()], trait] = Data.attr[trait, op] Then
        Inc Data.alive[Data.player()]

        Select Case op
            Case 1
                op1 = 2
                op2 = 3
            Case 2
                op1 = 1
                op2 = 3
            Case 3
                op1 = 2
                op2 = 3
        End

        eliminateOption(op1)
        eliminateOption(op2)
    Else
        eliminateOption(op)
    Endif

    If Data.alive[Data.player()] = 1 Or Data.alive[Data.player()] = 1 Then ' win by elimination
        Message.Info("Player " & (Data.player() + 1) & " has won.", "Ok")
        Data.Close()
        Start.Close()
        Lander.Close()
        HiddenCharacters.Close()
        Board.Close()
    Endif
End

Public Sub eliminateOption(option As Byte)
    Dim i As Byte

    For i = 0 To 23
        If Data.characters[i, trait] = Data.attr[trait, option] And Data.mock[Data.player(), i] <> "*" Then
            Data.mock[Data.player(), i] = "*"
            Dec Data.alive[Data.player()]
        Endif
    Next
End


'--------------------------------
' restore backup of characters[]
'--------------------------------
Public Sub restoreBackup()
    Dim i As Byte
    Dim j As Byte

    For i = 0 To 23
        For j = 0 To 10
            If Data.characters[i, j] <> backup[i, j] Then
                Inc Data.alive[Data.player()]
            Endif
            Data.characters[i, j] = backup[i, j]
        Next
        Data.mock[Data.player(), i] = backup[i, j]
    Next
End


'----------------------------
' mark eliminated characters
'----------------------------
Public Sub markEliminated()
    Dim i As Integer
    Dim j As Byte

    For i = 0 To 23
        If Data.mock[Data.player(), i] = "*" Then
            pb[0, i].Picture = Picture["img/no.png"]
            For j = 1 To 6
                pb[j, i].Picture = Picture["img/empty.png"]
            Next
        Endif

        Data.toggleOpponent()
        bottomRow[i].Picture = Picture[IIf(Data.mock[Data.player(), i] = "*", "img/no.png", "img/guess.png")]
        Data.toggleOpponent()
    Next
End


'--------------
' direct guess
'--------------
Public Sub Button25_Click()
    Dim i As Byte
    Dim result As Byte

    result = Message.Question("You have chosen the direct guess option. Do you want to continue?", "Yes", "No")

    If result = 1 Then
        For i = 0 To 23
            If Data.mock[Data.player(), i] <> "*" Then
                buttons[i].Enabled = True
            Endif
        Next
        MenuButton1.Visible = False
        MenuButton1.Text = "Traits"
        Button25.Enabled = False
        Button27.Visible = False
        Message.Info("Ready. Choose a character by pressing their name.", "Ok")
    Endif
End

Public Sub MenuClick3(i As Byte)
    Message.Info("Player " & (Data.player() + 1) & If(Data.hidden[Data.opponentIndex()] = i, " has won.", " has lost."), "Ok")
    Data.Close()
    Start.Close()
    Lander.Close()
    HiddenCharacters.Close()
    Board.Close()
End

