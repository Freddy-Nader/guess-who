' Gambas class file

pageIndex As Byte

Public Sub Form_Open()
    Label1.Text = "Objective"
    Label2.Text = "Be the first player to correctly guess the opponent's hidden character."
End

Public Sub Next_Click()
    Inc pageIndex
    
    If pageIndex = 7 Then
        Me.Hide()
        Lander.Show()
    Else 
        Select Case pageIndex
            Case 1
                Label1.Text = "Components"
                Label2.Text = "Two 6x4 boards, each with 24 characters. Each character has 10 distinct characteristics\n (such as hair, gender, eye color, etc.)."
            Case 2
                Label1.Text = "Game Start"
                Label2.Text = "At the beginning, the computer randomly generates two boards with characters and assigns a\n hidden character for each player."
            Case 3
                Label1.Text = "How to play"
                Label2.Alignment = 1
                Label2.Text = "- Turns: Players take turns asking questions about the characteristics of the opponent's\n hidden characters.\n- Asking: Use checkboxes to select the characteristic you want to ask about.\n- Response and Marking: The computer responds and marks the characters that do not match\n the asked characteristic.\n- Direct Guess: On any turn, you can choose to directly guess the opponent's hidden\n character. If the guess is incorrect, the game ends and you lose.\n- Number of Players: 2"
            Case 4
                Label2.Alignment = 3
                Label1.Text = "Game End"
                Label2.Text = "The player who first correctly guesses the opponent's hidden character wins. The game\n can also end if a player makes a direct guess and fails."
            Case 5
                Label1.Visible = False
                Label2.Y = 319
                Label2.Height = 326
                Label2.Text = "Note that at any point in the game the match can be ended with the button on the screen."
            Case 6
                Label2.Text = "Good luck!"
                Next.Text = "Thanks"
        End Select
    Endif
End
