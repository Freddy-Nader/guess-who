' Gambas class file

i As Byte

Public Sub Form_Open()
    Label1.Text = "Objetivo"
    Label2.Text = "Ser el primer jugador en adivinar correctamente el personaje oculto del oponente."
End

Public Sub Next_Click()
    Inc i
    
    If i = 7 Then
        Me.Hide()
        Lander.Show()
    Else 
        Select Case i
            Case 1
                Label1.Text = "Componentes"
                Label2.Text = "Dos tableros de 6x4, cada uno con 24 personajes. Cada personaje tiene 10 características distintas\n (como pelo, género, color de ojos, etc.)."
            Case 2
                Label1.Text = "Inicio del Juego"
                Label2.Text = "Al comenzar, la computadora genera aleatoriamente dos tableros con personajes y asigna un\n personaje oculto para cada jugador."
            Case 3
                Label1.Text = "Cómo jugar"
                Label2.Alignment = 1
                Label2.Text = "- Turnos: Los jugadores toman turnos para hacer preguntas sobre las características de los personajes\n ocultos del oponente.\n- Preguntar: Utiliza casillas de verificación para seleccionar la característica que deseas preguntar.\n- Respuesta y Marcación: La computadora responde y marca los personajes que no coinciden con\n la característica preguntada.\n- Adivinanza Directa: En cualquier turno, puedes optar por adivinar directamente el personaje oculto\n del oponente. Si la adivinanza es incorrecta, el juego termina y pierdes.\n- Número de Jugadores: 2"
            Case 4
                Label2.Alignment = 3
                Label1.Text = "Fin del Juego"
                Label2.Text = "Gana el jugador que primero adivine correctamente el personaje oculto del oponente. El juego\n también puede terminar si un jugador realiza una adivinanza directa y falla."
            Case 5
                Label1.Visible = False
                Label2.Y = 319
                Label2.Height = 326
                Label2.Text = "Nota que en cualquier punto del juego se puede finalizar la partida con el botón en pantalla."
            Case 6
                Label2.Text = "¡Buena suerte!"
                Next.Text = "Gracias"
        End Select
    Endif
End
