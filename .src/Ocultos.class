' Gambas class file

jugador[2] As Boolean

Private Sub selectJugador(id As Byte, btn As Object, color As Integer)
    macro()
    btn.Enabled = False
    Next.Background = color
    jugador[id] = True
    imagen(id)
    Label1.Text = "Jugador " & (id + 1)
    Label3.Text = Data.personajes[Data.oculto[id], 10]
End

Public Sub Button1_Click()
    selectJugador(0, Button1, &H5555AA)
End

Public Sub Button2_Click()
    selectJugador(1, Button2, &HAA0000)
End

Public Sub Next_Click()
    IIf(jugador[0], change(1), change(2))

    onoff(False)
    Next.Visible = False

    Label1.Text = "Personajes ocultos"
    Label2.Text = "Pulse el otro botón para ver su personaje oculto"
    Label2.Visible = True
    Label3.Visible = False
End

Public Sub change(i As Byte)
    Label3.Visible = False
    If jugador[0] And jugador[1] Then
        Me.Hide()
        Inicio.Show()
    Else
        If i = 1 Then Button2.Visible = True
        If i = 2 Then Button1.Visible = True
    Endif
End

Public Sub macro()
    Button1.Visible = False
    Button2.Visible = False
    Next.Visible = True
    
    Label2.Visible = False
    Label3.Visible = True
    
    onoff(True)
End

Public Sub onoff(valor As Boolean)
    piel.Visible = valor
    ropa.Visible = valor
    ojos.Visible = valor
    pecas.Visible = valor
    rasgos.Visible = valor
    pelo.Visible = valor
    acc.Visible = valor
End


Public Sub imagen(i As Byte)
    Dim k As Byte
    Dim m As Byte

    i = Data.oculto[i]

    ' piel
    For k = 1 To 3
        If Data.personajes[i, 1] = Data.car[1, k] Then
            piel.Picture = Picture["img/pb1" & k & ".png"]
            Break
        Endif
    Next
    
    ' ropa
    For k = 1 To 3
        If Data.personajes[i, 2] = Data.car[2, k] Then
            ropa.Picture = Picture["img/pb2" & k & ".png"]
            Break
        Endif
    Next
    
    ' ojos
    For k = 1 To 3
        For m = 1 To 3
            If Data.personajes[i, 3] = Data.car[3, k] And Data.personajes[i, 4] = Data.car[4, m] Then
                ojos.Picture = Picture["img/ojos" & k & m & ".png"]
                Break 2
            Endif
        Next
    Next
    
    ' pecas
    For k = 1 To 3
        If Data.personajes[i, 5] = Data.car[5, k] Then
            pecas.Picture = IIf(k = 3, Picture["img/empty.png"], Picture["img/pb5" & k & ".png"])
            Break
        Endif
    Next
    
    ' rasgos
    For k = 1 To 3
        If Data.personajes[i, 6] = Data.car[6, k] Then
            rasgos.Picture = IIf(k = 3, Picture["img/empty.png"], Picture["img/pb6" & k & ".png"])
            Break
        Endif
    Next
    
    ' pelo
    If Data.personajes[i, 7] = Data.car[7, 3] Then
        pelo.Picture = Picture["img/empty.png"]
    Else
        For k = 1 To 2
            For m = 1 To 3
                If Data.personajes[i, 7] = Data.car[7, k] And Data.personajes[i, 8] = Data.car[8, m] Then
                    pelo.Picture = Picture["img/pelo" & k & m & ".png"]
                    Break 2
                Endif
            Next
        Next
    Endif
    
    ' accesorios
    For k = 1 To 3
        If Data.personajes[i, 9] = Data.car[9, k] Then
            acc.Picture = IIf(k = 3, Picture["img/empty.png"], Picture["img/pb9" & k & ".png"])
            Break
        Endif
    Next
End
