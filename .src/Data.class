' Gambas class file

Public characters[24, 11] As String             ' [character, traits (11 = name)]
Public hidden[2] As Byte
Public alive[2] As Integer                      ' tracks how many characters each player has left
Public mock[2, 24] As String                    ' matrix that tracks which characters have been eliminated

Public attr[10, 4] As String                    ' [trait, options]; attr[i, 0] = trait name
Public names[2, 48] As String                   ' [gender, name]
Public menu[10] As String                       ' menus in 'Board.form'

Public opponent As Boolean                      ' False = player 1; True = player 2

Public Sub Form_Open()
    opponent = True
    alive[0] = 24
    alive[1] = 24
    initTraits()
    assignTraits()
End

Public Sub toggleOpponent() ' logical opponent toggle
    opponent = Not opponent
End

Public Function opponentIndex() As Byte ' numeric opponent index
    Return If(opponent, 1, 0)
End


Public Function player() As Byte
    Return If(opponent, 0, 1)
End


