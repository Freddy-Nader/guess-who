'--------------------------------------------
' asignacion de caracteristicas a personajes
'--------------------------------------------
Public Sub asignacion()
    Dim i As Byte                       ' primera dimension
    Dim j As Byte                       ' segunda dimension
    Dim r1 As Byte                      ' para random
    Dim r2 As Byte                      ' para random

    ' asignacion de caracteristicas
    For i = 0 To 23
        ' genero
        Repeat
            r1 = Int(Rnd(1, 3))
        Until r1 <> 3
        personajes[i, 0] = car[0, r1]
        
        ' nombre
        Repeat
            r2 = Int(Rnd(0, 48))
        Until r2 <> 48
        personajes[i, 10] = nombres[r1 - 1, r2]
        
        ' rasgo facial
        If r1 = 1 Then
            Repeat
                r2 = Int(Rnd(1, 4))
            Until r2 <> 4
            personajes[i, 6] = car[6, r2]
        Else
            personajes[i, 6] = car[6, 3] ' para que no haya mujeres con barba o bigote
        Endif 
        
        ' resto de caracteristicas
        For j = 1 To 9
            Repeat
                r1 = Int(Rnd(1, 4))
            Until r1 <> 4
            personajes[i, j] = car[j, r1]
            
            If j = 5 Then
                Inc j
            Endif
        Next
    Next
    
    ' eleccion de personajes ocultos
    For i = 0 To 1
        Repeat
            r1 = Int(Rnd(0, 24))
        Until r1 <> 24
        oculto[i] = r1
    Next

    ' info. de personajes ocultos
    For i = 0 To 1
        Print "El personaje oculto del jugador " & (i + 1) & " es " & (personajes[oculto[i], 10]) & " y tiene las siguientes características:"
        For j = 0 To 9
            Print (car[j, 0]) & ": " & (personajes[oculto[i], j])
        Next
        Print Null
    Next

    ' llenado de la matriz mock
    For i = 0 To 1
        For j = 0 To 23
            mock[i, j] = "-"
        Next
    Next
End


'-----------------------------------------
' info. de personajes restantes (consola)
'-----------------------------------------
Public Sub restantes()
    Dim i As Byte                       ' primera dimension
    Dim j As Byte                       ' segunda dimension

    ' numero
    For i = 0 To 1
        Print "El jugador " & (i + 1) & " tiene " & (vivos[i]) & " jugadores restantes."
    Next

    ' matriz
    Print "\nJugador 1\t\tJugador 2"
    For i = 0 To 3
        For j = 0 To 5
            Print mock[0, 6 * i + j];
        Next
        Print "\t\t",
        For j = 0 To 5
            Print mock[1, 6 * i + j];
        Next
        Print Null
    Next
End
