' Gambas class file

Public personajes[24, 11] As String             ' [personaje, caracteristicas (11 = nombre)]
Public oculto[2] As Byte
Public vivos[2] As Integer                      ' cuenta cuantos personajes le quedan a cada jugador
Public mock[2, 24] As String                    ' matriz en la que se muestra cuales personajes han sido adivinados 

Public car[10, 4] As String                     ' [caracteristica, opciones]; car[i, 0] = nombre de caracteristica
Public nombres[2, 48] As String                 ' [genero, nombre]
Public menu[10] As String                       ' menús en 'Plantilla.form'

Public oponente As Boolean                      ' False = jugador 1; True = jugador 2

Public Sub Form_Open()
    oponente = True
    vivos[0] = 24
    vivos[1] = 24
    caracteristicas()
    asignacion()
End

Public Sub oponenteL() ' oponente logico
    oponente = Not oponente
End

Public Function oponenteN() As Byte ' oponente numérico
    If oponente Then
        Return 1
    Else 
        Return 0
    Endif
End


Public Function jugador() As Byte
    If oponente Then
        Return 0
    Else 
        Return 1
    Endif
End


