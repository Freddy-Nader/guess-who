'--------------------------------------------
' assign traits to characters
'--------------------------------------------
Public Sub assignTraits()
    Dim i As Byte                       ' first dimension
    Dim j As Byte                       ' second dimension
    Dim r1 As Byte                      ' for random
    Dim r2 As Byte                      ' for random

    ' trait assignment
    For i = 0 To 23
        ' gender
        Repeat
            r1 = Int(Rnd(1, 3))
        Until r1 <> 3
        characters[i, 0] = attr[0, r1]

        ' name
        Repeat
            r2 = Int(Rnd(0, 48))
        Until r2 <> 48
        characters[i, 10] = names[r1 - 1, r2]

        ' facial features
        If r1 = 1 Then
            Repeat
                r2 = Int(Rnd(1, 4))
            Until r2 <> 4
            characters[i, 6] = attr[6, r2]
        Else
            characters[i, 6] = attr[6, 3] ' prevent female characters from having a beard or mustache
        Endif

        ' remaining traits
        For j = 1 To 9
            Repeat
                r1 = Int(Rnd(1, 4))
            Until r1 <> 4
            characters[i, j] = attr[j, r1]

            If j = 5 Then
                Inc j
            Endif
        Next
    Next

    ' select hidden characters
    For i = 0 To 1
        Repeat
            r1 = Int(Rnd(0, 24))
        Until r1 <> 24
        hidden[i] = r1
    Next

    ' hidden character info
    For i = 0 To 1
        Print "Player " & (i + 1) & "'s hidden character is " & (characters[hidden[i], 10]) & " and has the following traits:"
        For j = 0 To 9
            Print (attr[j, 0]) & ": " & (characters[hidden[i], j])
        Next
        Print Null
    Next

    ' fill the mock matrix
    For i = 0 To 1
        For j = 0 To 23
            mock[i, j] = "-"
        Next
    Next
End


'-----------------------------------------
' remaining characters info (console)
'-----------------------------------------
Public Sub printRemaining()
    Dim i As Byte                       ' first dimension
    Dim j As Byte                       ' second dimension

    ' count
    For i = 0 To 1
        Print "Player " & (i + 1) & " has " & (alive[i]) & " characters remaining."
    Next

    ' matrix
    Print "\nPlayer 1\t\tPlayer 2"
    For i = 0 To 3
        For j = 0 To 5
            Print mock[0, 6 * i + j];
        Next
        Print "\t\t",
        For j = 0 To 5
            Print mock[1, 6 * i + j];
        Next
        Print Null
    Next
End
