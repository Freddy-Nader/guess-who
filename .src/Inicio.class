' Gambas class file


Public Sub Form_Open()
    If Data.oponente Then
        Label1.Text = "Turno del Jugador 1"
    Else
        Label1.Text = "Turno del Jugador 2"
    Endif
End

Public Sub Button1_Click()
    Me.Close()
    Plantilla.Form_Open()
    Plantilla.MenuButton1.Visible = True
    Plantilla.MenuButton1.Menu = "Menu1"
    Plantilla.Show()
End
