' Gambas class file


Public Sub Form_Open()
    Label1.Text = If(Data.oponente, "Turno del Jugador 1", "Turno del Jugador 2")
End

Public Sub Button1_Click()
    Me.Close()
    Plantilla.Form_Open()
    Plantilla.MenuButton1.Visible = True
    Plantilla.MenuButton1.Menu = "Menu1"
    Plantilla.Show()
End
