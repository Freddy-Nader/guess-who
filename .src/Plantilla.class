'----------------------
' lógica de adivinanza
'----------------------
Public Sub adivinar()
    Dim i As Byte
    Dim j As Byte
    Dim op1 As Byte
    Dim op2 As Byte
    
    ' respaldo
    For i = 0 To 23
        For j = 0 To 10
            backup[i, j] = Data.personajes[i, j]
        Next
        backup[i, j] = Data.mock[Data.jugador(), i]
    Next
    
    If Data.personajes[Data.oculto[Data.oponenteN()], caracteristica] = Data.car[caracteristica, op] Then
        Inc Data.vivos[Data.jugador()]
        
        If op = 1 Then
            op1 = 2
            op2 = 3
        Else If op = 2 Then
            op1 = 1
            op2 = 3
        Else If op = 3 Then
            op1 = 2
            op2 = 3
        Endif
        
        opciones(op1)
        opciones(op2)
    Else 
        opciones(op)
    Endif
    
    If Data.vivos[Data.jugador()] = 1 Or Data.vivos[Data.jugador()] = 1 Then ' ganar por eliminación
        Message.Info("El jugador " & (Data.jugador() + 1) & " ha ganado.", "Ok")
        Data.Close()
        Inicio.Close()
        Lander.Close()
        Ocultos.Close()
        Plantilla.Close()
    Endif
End 

Public Sub opciones(opcion As Byte)
    Dim i As Byte
    
    For i = 0 To 23
        If Data.personajes[i, caracteristica] = Data.car[caracteristica, opcion] And Data.mock[Data.jugador(), i] <> "*" Then
            Data.mock[Data.jugador(), i] = "*"
            Dec Data.vivos[Data.jugador()]
        Endif
    Next
End


'---------------------------------
' respaldo de matriz personajes[]
'---------------------------------
Public Sub respaldar()
    Dim i As Byte
    Dim j As Byte
    
    For i = 0 To 23
        For j = 0 To 10
            If Data.personajes[i, j] <> backup[i, j] Then
                Inc Data.vivos[Data.jugador()]
            Endif
            Data.personajes[i, j] = backup[i, j]
        Next
        Data.mock[Data.jugador(), i] = backup[i, j]
    Next
End


'---------------------------
' marcar jugadores tachados
'---------------------------
Public Sub tachar()
    Dim i As Integer
    Dim j As Byte
    
    For i = 0 To 23
        If Data.mock[Data.jugador(), i] = "*" Then
            pb[0, i].Picture = Picture["no.png"]
            For j = 1 To 6
                pb[j, i].Picture = Picture["empty.png"]
            Next
        Endif 
        
        Data.oponenteL()
        If Data.mock[Data.jugador(), i] = "*" Then
            inferior[i].Picture = Picture["no.png"]
        Else 
            inferior[i].Picture = Picture["guess.png"]
        Endif
        Data.oponenteL()
    Next
End


'--------------------
' adivinanza directa
'--------------------
Public Sub Button25_Click()
    Dim i As Byte
    Dim resultado As Byte
    
    resultado = Message.Question("Ha escogido la opción de adivinanza directa. ¿Quiere seguir?", "Sí", "No")
    
    If resultado = 1 Then
        For i = 0 To 23
            If Data.mock[Data.jugador(), i] <> "*" Then 
                botones[i].Enabled = True
            Endif
        Next
        MenuButton1.Visible = False
        MenuButton1.Text = "Características"
        Button25.Enabled = False
        Button27.Visible = False
        Message.Info("Perfecto. Escoja un personaje presionando su nombre.", "Ok")
    Endif
End

Public Sub MenuClick3(i As Byte)
    If Data.oculto[Data.oponenteN()] = i Then
        Message.Info("El jugador " & (Data.jugador() + 1) & " ha ganado.", "Ok")
        Data.Close()
        Inicio.Close()
        Lander.Close()
        Ocultos.Close()
        Plantilla.Close()
    Else 
        Message.Info("El jugador " & (Data.jugador() + 1) & " ha perdido.", "Ok")
        Data.Close()
        Inicio.Close()
        Lander.Close()
        Ocultos.Close()
        Plantilla.Close()
    Endif
End

