        Else If Data.personajes[i, 9] = Data.car[9, 3] Then
            pb[6, i].Picture = Picture["empty.png"]
        Endif
    Next
    
    
    ' personaje oculto
    Label1.Text = Data.personajes[Data.oculto[Data.jugador()], 10]
    i = Data.oculto[Data.jugador()]
    
    ' piel
    If Data.personajes[i, 1] = Data.car[1, 1] Then
