' Gambas class file

puntacion[2] As Byte

' lógica de adivinanza
caracteristica As Byte
op As Byte
backup[24] As String

' eliminación de personajes
chosen[2, 10, 3] As Boolean

' arreglos de objetos
botones[24] As Object
pb[7, 25] As Object             ' piel, ropa, ojos, pecas, rasgos, pelo, accesorios (acc)
inferior[24] As Object

Public Sub Form_Open()
    Dim i As Byte
    
    macro()
    setup()
    tachar()
End


'-------------------------------------------------------------------------------
' cambiar botón "Características" a un botón con la característica seleccionada
'-------------------------------------------------------------------------------
Public Sub MenuClicks1(i As Byte)
    caracteristica = i
    MenuButton1.Text = Data.car[i, 0]
    MenuButton1.Menu = Data.menu[i]

    Button25.Enabled = False
End

Public Sub CarGrupo_Click()
    MenuClicks1(Last.Tag)
End


'---------------------------------------------------------
' pasar de menús a matrices y a eliminación de personajes
'---------------------------------------------------------
Public Sub MenuClicks2(i As Byte, j As Byte, k As Byte)
    op = i

    If chosen[Data.jugador(), j, k] Then
        Message.Info("Esta característica ya fue seleccionada anteriormente. Vuelva a intentarlo.", "Ok")
        reintentar()
        Return
    Endif

    adivinar()
    Data.restantes() ' consola

    If Data.vivos[Data.jugador()] = 0 Then
        Message.Info("Todos los personajes comparten esta característica. Vuelva a intentarlo.", "Ok")
        respaldar()
        reintentar()
    Else
        Inc puntacion[Data.jugador()]
        Label3.Text = "Puntación: " & (puntacion[Data.jugador()] * 10)
        chosen[Data.jugador(), j, k] = True

        MenuButton1.Visible = False
        MenuButton1.Text = "Características"
        Button25.Enabled = False
        Button27.Visible = True
    Endif

    tachar()
End

'----------------------------------------------
' restaurar la interfaz para repetir la pregunta
'----------------------------------------------
Private Sub reintentar()
    MenuButton1.Text = "Características"
    MenuButton1.Menu = "Menu1"
    MenuButton1.Visible = True
    Button25.Enabled = True
    Button27.Visible = False
End

Public Sub CarOpcion_Click()
    Dim t As Integer = Last.Tag

    MenuClicks2(t Mod 10, t \ 10, (t Mod 10) - 1)
End


'----------------------
' lógica de adivinanza
'----------------------
Public Sub adivinar()
    Dim i As Byte
    Dim k As Byte
    
    ' respaldo del tablero del jugador
    For i = 0 To 23
        backup[i] = Data.mock[Data.jugador(), i]
    Next
    
    If Data.personajes[Data.oculto[Data.oponenteN()], caracteristica] = Data.car[caracteristica, op] Then
        For k = 1 To 3
            If k <> op And Data.car[caracteristica, k] <> "" Then opciones(k)
        Next
    Else 
        opciones(op)
    Endif
    
    If Data.vivos[Data.jugador()] = 1 Then ' ganar por eliminación
        Message.Info("El jugador " & (Data.jugador() + 1) & " ha ganado.", "Ok")
        Data.Close()
        Inicio.Close()
        Lander.Close()
        Ocultos.Close()
        Plantilla.Close()
    Endif
End 

Public Sub opciones(opcion As Byte)
    Dim i As Byte
    
    For i = 0 To 23
        If Data.personajes[i, caracteristica] = Data.car[caracteristica, opcion] And Data.mock[Data.jugador(), i] <> "*" Then
            Data.mock[Data.jugador(), i] = "*"
            Dec Data.vivos[Data.jugador()]
        Endif
    Next
End


'---------------------------------
' respaldo de matriz personajes[]
'---------------------------------
Public Sub respaldar()
    Dim i As Byte

    Data.vivos[Data.jugador()] = 0
    For i = 0 To 23
        Data.mock[Data.jugador(), i] = backup[i]
        If backup[i] <> "*" Then
            Inc Data.vivos[Data.jugador()]
        Endif
    Next
End


'---------------------------
' marcar jugadores tachados
'---------------------------
Public Sub tachar()
    Dim i As Integer
    Dim j As Byte
    
    For i = 0 To 23
        If Data.mock[Data.jugador(), i] = "*" Then
            pb[0, i].Picture = Picture["img/no.png"]
            For j = 1 To 6
                pb[j, i].Picture = Picture["img/empty.png"]
            Next
        Endif 
        
        inferior[i].Picture = Picture[IIf(Data.mock[Data.oponenteN(), i] = "*", "img/no.png", "img/guess.png")]
    Next
End


'--------------------
' adivinanza directa
'--------------------
Public Sub Button25_Click()
    Dim i As Byte
    Dim resultado As Byte
    
    resultado = Message.Question("Ha escogido la opción de adivinanza directa. ¿Quiere seguir?", "Sí", "No")
    
    If resultado = 1 Then
        For i = 0 To 23
            If Data.mock[Data.jugador(), i] <> "*" Then 
                botones[i].Enabled = True
            Endif
        Next
        MenuButton1.Visible = False
        MenuButton1.Text = "Características"
        Button25.Enabled = False
        Button27.Visible = False
        Message.Info("Perfecto. Escoja un personaje presionando su nombre.", "Ok")
    Endif
End

Public Sub MenuClick3(i As Byte)
    Message.Info("El jugador " & (Data.jugador() + 1) & If(Data.oculto[Data.oponenteN()] = i, " ha ganado.", " ha perdido."), "Ok")
    Data.Close()
    Inicio.Close()
    Lander.Close()
    Ocultos.Close()
    Plantilla.Close()
End

Public Sub Botones_Click()
    MenuClick3(Last.Tag)
End



'-----------
' finalizar
'-----------
Public Sub Button26_Click()
    Message.Info("El jugador " & (Data.jugador() + 1) & " ha finalizado el juego.", "Ok")
    Data.Close()
    Inicio.Close()
    Lander.Close()
    Ocultos.Close()
    Plantilla.Close()
End


'-----------
' continuar
'-----------
Public Sub Button27_Click()
    Me.Hide()
    Data.oponenteL()
    Inicio.Show()
End


'---------------------
' arreglos de objetos
'---------------------
Public Sub macro()
    Dim c As Control
    Dim prefijos As String[] = ["piel", "ropa", "ojos", "pecas", "rasgos", "pelo", "acc"]
    Dim j As Integer
    Dim n As Integer

    For Each c In Me.Children
        If c.Name Like "Button[0-9]*" Then
            n = CInt(Mid$(c.Name, 7))
            If n <= 24 Then botones[n - 1] = c
            Continue
        Endif
        If c.Name Like "inf[0-9]*" Then
            inferior[CInt(Mid$(c.Name, 4)) - 1] = c
            Continue
        Endif
        For j = 0 To 6
            If c.Name Like prefijos[j] & "[0-9]*" Then
                pb[j, CInt(Mid$(c.Name, Len(prefijos[j]) + 1)) - 1] = c
                Break
            Endif
        Next
    Next
End

'----------------------
' imagenes y plantilla
'----------------------
Public Sub setup()
    Dim i As Byte
    
    Button27.Visible = False
    Button25.Enabled = True
    
    Label4.Text = "Jugador " & (Data.jugador() + 1)
    Label3.Text = "Puntación: " & (puntacion[Data.jugador()] * 10)
    
    For i = 0 To 23
        botones[i].Text = Data.personajes[i, 10]
        drawPersonaje(i, i)
    Next 
    
    ' personaje oculto
    i = Data.oculto[Data.jugador()]
    Label1.Text = Data.personajes[i, 10]
    drawPersonaje(i, 24)
End

Private Sub drawPersonaje(src As Byte, dest As Byte)
    Dim k As Byte
    Dim m As Byte

    ' piel
    For k = 1 To 3
        If Data.personajes[src, 1] = Data.car[1, k] Then
            pb[0, dest].Picture = Picture["img/pb1" & k & ".png"]
            Break
        Endif
    Next

    ' ropa
    For k = 1 To 3
        If Data.personajes[src, 2] = Data.car[2, k] Then
            pb[1, dest].Picture = Picture["img/pb2" & k & ".png"]
            Break
        Endif
    Next

    ' ojos
    For k = 1 To 3
        For m = 1 To 3
            If Data.personajes[src, 3] = Data.car[3, k] And Data.personajes[src, 4] = Data.car[4, m] Then
                pb[2, dest].Picture = Picture["img/ojos" & k & m & ".png"]
                Break 2
            Endif
        Next
    Next

    ' pecas
    For k = 1 To 3
        If Data.personajes[src, 5] = Data.car[5, k] Then
            pb[3, dest].Picture = IIf(k = 3, Picture["img/empty.png"], Picture["img/pb5" & k & ".png"])
            Break
        Endif
    Next

    ' rasgos
    For k = 1 To 3
        If Data.personajes[src, 6] = Data.car[6, k] Then
            pb[4, dest].Picture = IIf(k = 3, Picture["img/empty.png"], Picture["img/pb6" & k & ".png"])
            Break
        Endif
    Next

    ' pelo
    If Data.personajes[src, 7] = Data.car[7, 3] Then
        pb[5, dest].Picture = Picture["img/empty.png"]
    Else
        For k = 1 To 2
            For m = 1 To 3
                If Data.personajes[src, 7] = Data.car[7, k] And Data.personajes[src, 8] = Data.car[8, m] Then
                    pb[5, dest].Picture = Picture["img/pelo" & k & m & ".png"]
                    Break 2
                Endif
            Next
        Next
    Endif

    ' accesorios
    For k = 1 To 3
        If Data.personajes[src, 9] = Data.car[9, k] Then
            pb[6, dest].Picture = IIf(k = 3, Picture["img/empty.png"], Picture["img/pb9" & k & ".png"])
            Break
        Endif
    Next
End
