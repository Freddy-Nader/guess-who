'-----------
' finalizar
'-----------
Public Sub Button26_Click()
    Message.Info("El jugador " & (Data.jugador() + 1) & " ha finalizado el juego.", "Ok")
    Data.Close()
    Inicio.Close()
    Lander.Close()
    Ocultos.Close()
    Plantilla.Close()
End


'-----------
' continuar
'-----------
Public Sub Button27_Click()
    Me.Hide()
    Data.oponenteL()
    Inicio.Show()
End


