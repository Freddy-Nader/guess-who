            pb[2, i].Picture = Picture["ojos22.png"]
        Else If Data.personajes[i, 3] = Data.car[3, 3] And Data.personajes[i, 4] = Data.car[4, 3] Then
            pb[2, i].Picture = Picture["ojos23.png"]
        Endif
        
        ' pecas
        If Data.personajes[i, 5] = Data.car[5, 1] Then
