' Gambas class file

' Entry point for the landing page
Public Sub Form_Open()
    Data.Form_Open()
End

' Start the game by hiding the landing page and showing the hidden character setup
Public Sub btnPlay_Click()
    Me.Hide()
    HiddenCharacters.Show()
End

' Show the info/how to play screen
Public Sub btnInfo_Click()
    Info.Show()
    Me.Hide()
End
